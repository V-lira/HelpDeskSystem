<UserControl x:Class="HelpDeskSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer>
        <StackPanel Margin="20">
            <!-- HEAD -->
            <TextBlock Text="Dashboard" FontSize="34" FontWeight="Bold" Margin="0 0 0 30"/>
            <!-- stats -->
            <UniformGrid Columns="4" Margin="0 0 0 30">
                <!-- tototal -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Всего инцидентов" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="TotalText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Open -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Открытые" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="OpenText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Overdue -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Просроченные" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="OverdueText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Critical -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Критические" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="CriticalText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>
            <!-- Recent incidents -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Последние инциденты" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <DataGrid x:Name="RecentIncidentsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="150"/>
                            <DataGridTextColumn Header="Тема" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="180"/>
                            <DataGridTextColumn Header="Исполнитель" Binding="{Binding AssignedUser}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>