<UserControl x:Class="HelpDeskSystem.Views.IncidentDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer>

        <StackPanel Margin="30">
            <Button Content="← Назад" Width="140" Height="40" Margin="0 0 0 20" Click="BackButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <TextBlock x:Name="TitleText" FontSize="30" FontWeight="Bold" Margin="0 0 0 25"/>
            <!-- Info -->
            <materialDesign:Card Padding="20" Margin="0 0 0 25">
                <StackPanel>
                    <TextBlock x:Name="NumberText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="CategoryText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="DepartmentText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="AuthorText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="PriorityText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="StatusText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="AssignedText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="CreatedText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="DeadlineText" FontSize="18"/>
                </StackPanel>
            </materialDesign:Card>
            <!-- Comments -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Комментарии" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <!-- Add -->
                    <TextBox x:Name="CommentTextBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0 0 0 15" materialDesign:HintAssist.Hint="Введите комментарий"/>
                    <Button Content="💬 Добавить комментарий" Height="45" Width="250" Margin="0 0 0 20" HorizontalAlignment="Left" Click="AddCommentButton_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <!-- Comments list -->
                    <ListBox x:Name="CommentsListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Margin="0 0 0 15" Padding="15">
                                    <StackPanel>
                                        <!-- Header -->
                                        <DockPanel Margin="0 0 0 10">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="{Binding Author}" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{Binding CreatedAt}" Opacity="0.6" FontSize="12"/>
                                            </StackPanel>
                                            <!-- Actions -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <!-- Edit -->
                                                <Button Content="✏️" Width="40" Height="35" Margin="0 0 10 0" Click="EditCommentButton_Click" Tag="{Binding Id}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                                <!-- Delete -->
                                                <Button Content="🗑"  Width="40" Height="35" Click="DeleteCommentButton_Click" Tag="{Binding Id}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <!-- Message -->
                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="15"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>