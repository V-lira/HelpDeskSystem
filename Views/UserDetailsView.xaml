<UserControl x:Class="HelpDeskSystem.Views.UserDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer>

        <StackPanel Margin="30">
            <Button Content="← Назад" Width="120" Height="40" Margin="0 0 0 20" Click="BackButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <TextBlock x:Name="FullNameText" FontSize="32" FontWeight="Bold" Margin="0 0 0 25"/>
            <!-- main Info -->
            <materialDesign:Card Padding="20" Margin="0 0 0 25">
                <StackPanel>
                    <TextBlock x:Name="RoleText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="DepartmentText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="EmailText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="WorkHoursText" FontSize="18" Margin="0 0 0 10"/>
                    <TextBlock x:Name="CreatedAtText" FontSize="18"/>
                </StackPanel>
            </materialDesign:Card>
            <!-- Statistics -->
            <TextBlock Text="Статистика" FontSize="26" FontWeight="Bold" Margin="0 0 0 20"/>
            <UniformGrid Columns="3" Margin="0 0 0 25">
                <!-- Total -->
                <materialDesign:Card Margin="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Всего инцидентов" FontSize="18" Opacity="0.7"/>
                        <TextBlock x:Name="TotalIncidentsText" FontSize="34" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Closed -->
                <materialDesign:Card Margin="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Закрыто" FontSize="18" Opacity="0.7"/>
                        <TextBlock x:Name="ClosedIncidentsText" FontSize="34" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Active -->
                <materialDesign:Card Margin="10" Padding="20">
                    <StackPanel>
                        <TextBlock Text="В работе" FontSize="18" Opacity="0.7"/>
                        <TextBlock x:Name="ActiveIncidentsText" FontSize="34" FontWeight="Bold"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>