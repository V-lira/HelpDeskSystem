<UserControl x:Class="HelpDeskSystem.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Header -->
        <DockPanel Margin="0 0 0 20">
            <TextBlock Text="Пользователи" FontSize="32" FontWeight="Bold" DockPanel.Dock="Left"/>
            <TextBox x:Name="SearchTextBox" Margin="0 0 0 15" Height="40" materialDesign:HintAssist.Hint="Поиск пользователей..." TextChanged="SearchTextBox_TextChanged"/>
            <Button Content="➕ Добавить пользователя" Width="240" Height="45" HorizontalAlignment="Right" Style="{StaticResource MaterialDesignRaisedButton}" Click="AddUserButton_Click"/>
        </DockPanel>
        <!-- Table -->
        <materialDesign:Card Grid.Row="1" Padding="20">
            <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" HorizontalScrollBarVisibility="Auto" MouseDoubleClick="UsersGrid_MouseDoubleClick" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="260"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="180"/>
                    <DataGridTextColumn Header="Отдел" Binding="{Binding Department}" Width="220"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="250"/>
                    <DataGridTextColumn Header="Рабочие часы" Binding="{Binding WorkHours}" Width="180"/>
                    <DataGridTemplateColumn Header="Действия" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Width="40" Height="35" Margin="0 0 10 0" Tag="{Binding Id}" Click="EditUserButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <Button Content="🗑" Width="40" Height="35" Tag="{Binding Id}" Click="DeleteUserButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>