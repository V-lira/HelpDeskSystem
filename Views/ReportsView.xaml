<UserControl x:Class="HelpDeskSystem.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer>

        <StackPanel Margin="20">

            <!-- Header -->
            <TextBlock Text="📊 Отчёты" FontSize="34" FontWeight="Bold" Margin="0 0 0 30"/>
            <!-- Statistics -->
            <UniformGrid Columns="4" Margin="0 0 0 30">
                <!-- Total -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Всего" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="TotalText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Closed -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Закрытые" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="ClosedText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Critical -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Критические" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="CriticalText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
                <!-- Overdue -->
                <materialDesign:Card Margin="10" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Просроченные" FontSize="16" Opacity="0.7"/>
                        <TextBlock x:Name="OverdueText" FontSize="38" FontWeight="Bold" Margin="0 10 0 0"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>
            <!-- export blk -->
            <materialDesign:Card Padding="30">
                <StackPanel>
                    <TextBlock Text="Экспорт отчётов" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <WrapPanel>
                        <Button Content="📄 Экспорт CSV" Width="220" Height="50" Margin="0 0 20 0" Click="ExportCsvButton_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                        <Button Content="📝 Экспорт TXT" Width="220" Height="50" Click="ExportTxtButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>