<UserControl x:Class="HelpDeskSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer>

        <StackPanel Margin="30">

            <!-- Header -->
            <TextBlock Text="Настройки системы" FontSize="32" FontWeight="Bold" Margin="0 0 0 30"/>
            <!-- Appearance -->
            <materialDesign:Card Padding="20" Margin="0 0 0 25">
                <StackPanel>
                    <TextBlock Text="🎨 Внешний вид" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <TextBlock Text="Тема приложения" FontWeight="SemiBold" Margin="0 0 0 10"/>
                    <ComboBox x:Name="ThemeComboBox" Width="250" SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </StackPanel>
            </materialDesign:Card>
            <!-- Database -->
            <materialDesign:Card Padding="20" Margin="0 0 0 25">
                <StackPanel>
                    <TextBlock Text="💾 База данных" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <TextBlock x:Name="DatabasePathText" FontSize="16" Margin="0 0 0 10"/>
                    <TextBlock x:Name="DatabaseSizeText" FontSize="16"/>
                </StackPanel>
            </materialDesign:Card>
            <!-- Statistics -->
            <materialDesign:Card Padding="20" Margin="0 0 0 25">
                <StackPanel>
                    <TextBlock Text="📊 Статистика системы" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <TextBlock x:Name="IncidentsCountText" FontSize="16" Margin="0 0 0 10"/>
                    <TextBlock x:Name="CommentsCountText" FontSize="16" Margin="0 0 0 10"/>
                    <TextBlock x:Name="UsersCountText" FontSize="16"/>
                </StackPanel>
            </materialDesign:Card>
            <!-- System -->
            <materialDesign:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="🖥 Система" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>
                    <TextBlock Text=".NET Framework 4.8" FontSize="16" Margin="0 0 0 10"/>
                    <TextBlock Text="Material Design in XAML" FontSize="16" Margin="0 0 0 10"/>
                    <TextBlock Text="HelpDeskSystem v1.0" FontSize="16"/>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>